---
/**
 * CMS editor — side-by-side MDX editor + live preview iframe.
 * Served at /_cms/edit/<slug> (dev only).
 *
 * - Reads the current file content via the content API on load
 * - Saves changes via POST to the content API
 * - Preview iframe points at /preview/<slug> and refreshes on save
 * - __new__ slug presents a blank file with a name input
 * - Asset drawer: upload images to src/assets/, copy MDX snippet to clipboard (MDX mode only)
 * - Rich Editor toggle: form-based frontmatter + MDXEditor body for non-MDX authors
 */
export const prerender = false;

import RichBodyEditor from '../RichBodyEditor.tsx';

const { slug } = Astro.params;
const isNew = slug === '__new__';
const cmsBase = import.meta.env.GITCMS_BASE ?? '/_cms';
const frontmatterFields = import.meta.env.GITCMS_FRONTMATTER ?? '[]';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{isNew ? 'New page — gitcms' : `Edit: ${slug} — gitcms`}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        height: 100%;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 14px;
        background: #0f172a;
        color: #e2e8f0;
        overflow: hidden;
      }

      .layout {
        display: grid;
        grid-template-rows: 52px 1fr;
        height: 100vh;
      }

      /* ── Topbar ─────────────────────────────────────────────── */
      .topbar {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 1rem;
        background: #1e293b;
        border-bottom: 1px solid #334155;
        overflow: hidden;
      }

      .topbar__back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #94a3b8;
        text-decoration: none;
        font-size: 13px;
        padding: 4px 8px;
        border-radius: 4px;
        white-space: nowrap;
        transition: color 150ms, background 150ms;
      }
      .topbar__back:hover { color: #e2e8f0; background: #334155; }

      .topbar__sep { color: #334155; user-select: none; }

      .topbar__slug {
        font-family: 'Fira Code', monospace;
        font-size: 13px;
        color: #818cf8;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .topbar__slug-input {
        font-family: 'Fira Code', monospace;
        font-size: 13px;
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 4px;
        color: #818cf8;
        padding: 4px 8px;
        flex: 1;
        min-width: 0;
        max-width: 320px;
        outline: none;
      }
      .topbar__slug-input:focus { border-color: #4f46e5; }
      .topbar__slug-input::placeholder { color: #475569; }

      .topbar__status {
        font-size: 12px;
        color: #64748b;
        white-space: nowrap;
        min-width: 80px;
        text-align: right;
      }
      .topbar__status--saving { color: #facc15; }
      .topbar__status--saved  { color: #4ade80; }
      .topbar__status--error  { color: #f87171; }

      .save-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 16px;
        background: #4f46e5;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: background 150ms;
      }
      .save-btn:hover:not(:disabled) { background: #4338ca; }
      .save-btn:disabled { opacity: 0.5; cursor: not-allowed; }

      .preview-btn {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        background: transparent;
        color: #4ade80;
        border: 1px solid #4ade80;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        white-space: nowrap;
        transition: background 150ms;
      }
      .preview-btn:hover { background: #1a2e1a; }

      /* ── Editor panes ───────────────────────────────────────── */
      .panes {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100%;
        overflow: hidden;
      }

      .pane {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-right: 1px solid #1e293b;
      }
      .pane:last-child { border-right: none; }

      .pane__header {
        display: flex;
        align-items: center;
        padding: 6px 12px;
        background: #1e293b;
        border-bottom: 1px solid #334155;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #64748b;
        gap: 8px;
        flex-shrink: 0;
      }

      .pane__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #334155;
      }
      .pane--editor .pane__dot { background: #818cf8; }
      .pane--preview .pane__dot { background: #4ade80; }

      /* ── Mode switcher ──────────────────────────────────────── */
      .mode-switcher {
        display: inline-flex;
        border: 1px solid #334155;
        border-radius: 4px;
        overflow: hidden;
      }

      .mode-btn {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        background: #0f172a;
        border: none;
        border-right: 1px solid #334155;
        color: #64748b;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 150ms, color 150ms;
      }
      .mode-btn:last-child { border-right: none; }
      .mode-btn:hover { color: #94a3b8; }
      .mode-btn[aria-pressed='true'] {
        background: #1e293b;
        color: #e2e8f0;
      }

      .assets-toggle {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 4px;
        color: #94a3b8;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
        transition: border-color 150ms, color 150ms;
      }
      .assets-toggle:hover,
      .assets-toggle[aria-expanded='true'] { border-color: #818cf8; color: #818cf8; }

      /* ── MDX editor ─────────────────────────────────────────── */
      .editor-textarea {
        flex: 1;
        width: 100%;
        padding: 1.25rem;
        background: #0f172a;
        color: #e2e8f0;
        border: none;
        resize: none;
        font-family: 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
        font-size: 13px;
        line-height: 1.7;
        outline: none;
        tab-size: 2;
      }

      /* ── Rich editor ────────────────────────────────────────── */
      .rich-editor {
        display: none;
        flex-direction: column;
        flex: 1;
        overflow: hidden;
        background: #0f172a;
      }
      .rich-editor.is-active { display: flex; }

      .fm-form {
        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 1rem 1.25rem 0;
        border-bottom: 1px solid #1e293b;
        padding-bottom: 1rem;
        flex-shrink: 0;
      }

      .fm-form__heading {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #475569;
        margin: 0 0 0.75rem;
      }

      .fm-field {
        display: grid;
        grid-template-columns: 120px 1fr;
        align-items: center;
        gap: 8px;
        padding: 5px 0;
        border-bottom: 1px solid #1e293b;
      }
      .fm-field:last-child { border-bottom: none; }

      .fm-label {
        font-size: 12px;
        font-weight: 600;
        color: #64748b;
        user-select: none;
      }
      .fm-label--required::after {
        content: ' *';
        color: #f87171;
      }

      .fm-input {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 4px;
        color: #e2e8f0;
        font-family: inherit;
        font-size: 13px;
        padding: 5px 8px;
        outline: none;
        width: 100%;
        transition: border-color 150ms;
      }
      .fm-input:focus { border-color: #4f46e5; }
      .fm-input::placeholder { color: #475569; }

      .fm-checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .fm-checkbox {
        width: 16px;
        height: 16px;
        accent-color: #4f46e5;
        cursor: pointer;
        flex-shrink: 0;
      }

      .body-section {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 1rem 1.25rem;
        gap: 0.5rem;
        min-height: 0;
        overflow: hidden;
      }

      .body-section__heading {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #475569;
        margin: 0;
        flex-shrink: 0;
      }

      /* MDXEditor container — fills remaining body-section space */
      .rich-body-editor {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid #334155;
        border-radius: 6px;
        background: #1c1c1e;
      }

      /* Override MDXEditor internals to fit our layout */
      .rich-body-editor .mdxeditor {
        height: 100%;
        flex: 1;
        display: flex;
        flex-direction: column;
        background: transparent;
      }
      .rich-body-editor .mdxeditor-toolbar {
        border-bottom: 1px solid #334155;
        background: #1e293b;
        flex-shrink: 0;
      }
      .rich-body-editor__content {
        flex: 1;
        padding: 1rem 1.25rem;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 15px;
        line-height: 1.7;
        color: #e2e8f0;
        min-height: 200px;
        caret-color: #e2e8f0;
      }

      /* ── Preview pane ───────────────────────────────────────── */
      .preview-frame {
        flex: 1;
        width: 100%;
        border: none;
        background: #fff;
      }

      .preview-placeholder {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #475569;
        font-size: 13px;
        font-style: italic;
      }

      /* ── Asset drawer ───────────────────────────────────────── */
      .asset-drawer {
        flex-shrink: 0;
        background: #0f1f38;
        border-top: 1px solid #334155;
        display: none;
        flex-direction: column;
        max-height: 280px;
        overflow: hidden;
      }
      .asset-drawer.is-open { display: flex; }

      .asset-drawer__toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-bottom: 1px solid #1e293b;
        flex-shrink: 0;
      }

      .upload-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        background: #4f46e5;
        color: #fff;
        border-radius: 5px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: background 150ms;
        white-space: nowrap;
      }
      .upload-label:hover { background: #4338ca; }

      #asset-file-input { display: none; }

      .upload-status {
        font-size: 12px;
        color: #64748b;
      }
      .upload-status--uploading { color: #facc15; }
      .upload-status--ok  { color: #4ade80; }
      .upload-status--err { color: #f87171; }

      .asset-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        gap: 8px;
        padding: 10px 12px;
        overflow-y: auto;
        flex: 1;
      }

      .asset-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        padding: 6px;
        border-radius: 6px;
        border: 1px solid transparent;
        transition: border-color 150ms, background 150ms;
        position: relative;
      }
      .asset-item:hover { border-color: #4f46e5; background: #1e293b; }

      .asset-item__thumb {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 4px;
        background: #1e293b;
      }

      .asset-item__name {
        font-size: 10px;
        color: #64748b;
        text-align: center;
        width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .asset-item__copied {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgb(79 70 229 / 0.85);
        border-radius: 6px;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        opacity: 0;
        transition: opacity 150ms;
        pointer-events: none;
      }
      .asset-item.did-copy .asset-item__copied { opacity: 1; }

      .asset-empty {
        grid-column: 1 / -1;
        padding: 1.5rem;
        text-align: center;
        color: #475569;
        font-size: 12px;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <header class="topbar">
        <a class="topbar__back" href={cmsBase}>← Content</a>
        <span class="topbar__sep">/</span>

        {isNew
          ? <input
              id="slug-input"
              class="topbar__slug-input"
              type="text"
              placeholder="page-slug (e.g. about or blog/my-post)"
              autocomplete="off"
              spellcheck="false"
            />
          : <span class="topbar__slug">{slug}.mdx</span>
        }

        <span id="status" class="topbar__status"></span>

        {!isNew && (
          <a
            id="preview-link"
            class="preview-btn"
            href={`/preview/${slug}`}
            target="_blank"
          >
            Preview ↗
          </a>
        )}

        <button id="save-btn" class="save-btn">Save</button>
      </header>

      <div class="panes">
        <div class="pane pane--editor">
          <div class="pane__header">
            <span class="pane__dot"></span>
            Editor
            <div class="mode-switcher" role="group" aria-label="Editor mode">
              <button id="mode-btn-rich" class="mode-btn" aria-pressed="true">Rich</button>
              <button id="mode-btn-mdx"  class="mode-btn" aria-pressed="false">MDX</button>
            </div>
            <button
              id="assets-toggle"
              class="assets-toggle"
              aria-expanded="false"
              aria-controls="asset-drawer"
              title="Toggle image assets"
              style="display:none"
            >
              Images
            </button>
          </div>

          <!-- MDX mode: raw textarea (hidden by default, JS switches modes) -->
          <textarea
            id="editor"
            class="editor-textarea"
            style="display:none"
            spellcheck="false"
            autocomplete="off"
            placeholder="---&#10;title: My Page&#10;description: A brief description&#10;---&#10;&#10;# Hello&#10;&#10;Start writing your page content here."
          ></textarea>

          <!-- Rich mode: frontmatter form + body textarea (default) -->
          <div id="rich-editor" class="rich-editor is-active">
            <div class="fm-form">
              <p class="fm-form__heading">Frontmatter</p>
              <div id="fm-fields"></div>
            </div>
            <div class="body-section">
              <p class="body-section__heading">Content</p>
              <RichBodyEditor
                client:only="react"
                cmsBase={cmsBase}
              />
            </div>
          </div>

          <!-- Asset drawer sits below the editor, inside the editor pane -->
          <div id="asset-drawer" class="asset-drawer" role="region" aria-label="Image assets">
            <div class="asset-drawer__toolbar">
              <label class="upload-label" for="asset-file-input">
                + Upload image
              </label>
              <input
                id="asset-file-input"
                type="file"
                accept="image/jpeg,image/png,image/gif,image/webp,image/avif,image/svg+xml"
                multiple
              />
              <span id="upload-status" class="upload-status"></span>
            </div>
            <div id="asset-grid" class="asset-grid">
              <div class="asset-empty">Loading assets…</div>
            </div>
          </div>
        </div>

        <div class="pane pane--preview">
          <div class="pane__header">
            <span class="pane__dot"></span>
            Preview
            {!isNew && <span style="margin-left:auto;font-size:10px;color:#334155;text-transform:none;letter-spacing:0">(saves to refresh)</span>}
          </div>
          {isNew
            ? <div class="preview-placeholder">Save the page first to see a preview</div>
            : <iframe id="preview-frame" class="preview-frame" src={`/preview/${slug}`}></iframe>
          }
        </div>
      </div>
    </div>

    <script define:vars={{ slug, isNew, cmsBase, frontmatterFields }}>
      // ── Field config ───────────────────────────────────────────
      const FIELDS = typeof frontmatterFields === 'string'
        ? JSON.parse(frontmatterFields)
        : (frontmatterFields ?? []);

      // ── DOM refs ───────────────────────────────────────────────
      const editor       = document.getElementById('editor');
      const richEditor   = document.getElementById('rich-editor');
      const fmFields     = document.getElementById('fm-fields');
      const saveBtn      = document.getElementById('save-btn');
      const statusEl     = document.getElementById('status');
      const slugInput    = document.getElementById('slug-input');
      const previewFrame = document.getElementById('preview-frame');
      const modeBtnRich  = document.getElementById('mode-btn-rich');
      const modeBtnMdx   = document.getElementById('mode-btn-mdx');
      const assetsToggle = document.getElementById('assets-toggle');
      const assetDrawer  = document.getElementById('asset-drawer');
      const assetGrid    = document.getElementById('asset-grid');
      const fileInput    = document.getElementById('asset-file-input');
      const uploadStatus = document.getElementById('upload-status');

      let dirty = false;
      let currentSlug = isNew ? null : slug;
      let activeMode = 'rich'; // 'mdx' | 'rich'

      // ── React island communication ─────────────────────────────
      // Instead of events, we read/write the editor directly via functions
      // the React island exposes on window after it mounts.

      function getRichBody() {
        return window.__gitcmsGetBody ? window.__gitcmsGetBody() : '';
      }

      function setRichBody(markdown) {
        window.__gitcmsInitialBody = markdown;
        if (window.__gitcmsSetBody) {
          window.__gitcmsSetBody(markdown);
        }
        // If the island hasn't mounted yet, __gitcmsInitialBody is enough —
        // the component reads it directly on mount.
      }

      // Mark dirty on any input in the rich editor form fields.
      // (Body edits are tracked via the onChange → gitcms:body-change path
      //  which we keep as a lightweight dirty signal only.)
      window.addEventListener('gitcms:body-change', () => {
        if (!dirty) { dirty = true; setStatus('Unsaved changes', ''); }
      });

      // ── Build rich editor form fields ─────────────────────────
      for (const field of FIELDS) {
        const row = document.createElement('div');
        row.className = 'fm-field';

        const label = document.createElement('label');
        label.className = 'fm-label' + (field.required ? ' fm-label--required' : '');
        label.textContent = field.label;
        label.htmlFor = `fm-${field.key}`;

        let control;
        if (field.type === 'boolean') {
          const wrapper = document.createElement('div');
          wrapper.className = 'fm-checkbox-wrapper';
          control = document.createElement('input');
          control.type = 'checkbox';
          control.className = 'fm-checkbox';
          control.id = `fm-${field.key}`;
          control.dataset.fmKey = field.key;
          control.dataset.fmType = 'boolean';
          wrapper.appendChild(control);
          row.appendChild(label);
          row.appendChild(wrapper);
        } else {
          control = document.createElement('input');
          control.type = 'text';
          control.className = 'fm-input';
          control.id = `fm-${field.key}`;
          control.dataset.fmKey = field.key;
          control.dataset.fmType = 'text';
          if (field.required) control.required = true;
          row.appendChild(label);
          row.appendChild(control);
        }

        control.addEventListener('input', () => {
          if (!dirty) { dirty = true; setStatus('Unsaved changes', ''); }
        });

        fmFields.appendChild(row);
      }

      // ── Mode switching ─────────────────────────────────────────

      function parseMdx(raw) {
        const fm = {};
        const unknownLines = [];
        let body = raw;

        const fmMatch = raw.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n?([\s\S]*)$/);
        if (fmMatch) {
          const yamlBlock = fmMatch[1];
          body = fmMatch[2] ?? '';

          const knownKeys = new Set(FIELDS.map(f => f.key));

          for (const line of yamlBlock.split('\n')) {
            const colonIdx = line.indexOf(':');
            if (colonIdx === -1) {
              unknownLines.push(line);
              continue;
            }
            const key = line.slice(0, colonIdx).trim();
            const rawVal = line.slice(colonIdx + 1).trim();

            if (knownKeys.has(key)) {
              if (rawVal === 'true') fm[key] = true;
              else if (rawVal === 'false') fm[key] = false;
              else fm[key] = rawVal;
            } else {
              unknownLines.push(line);
            }
          }
        }

        return { fm, unknownLines, body };
      }

      function serializeToMdx() {
        const lines = [];

        for (const field of FIELDS) {
          const el = document.getElementById(`fm-${field.key}`);
          if (!el) continue;
          if (field.type === 'boolean') {
            lines.push(`${field.key}: ${el.checked}`);
          } else {
            const val = el.value.trim();
            if (val || field.required) lines.push(`${field.key}: ${val}`);
          }
        }

        const stored = richEditor.dataset.unknownLines;
        if (stored) {
          const extras = JSON.parse(stored);
          if (extras.length) lines.push(...extras);
        }

        const fm = lines.length ? `---\n${lines.join('\n')}\n---\n\n` : '';
        return fm + getRichBody();
      }

      function activateMode(mode) {
        if (mode === 'rich') {
          const { fm, unknownLines, body } = parseMdx(editor.value);

          for (const field of FIELDS) {
            const el = document.getElementById(`fm-${field.key}`);
            if (!el) continue;
            if (field.type === 'boolean') {
              el.checked = fm[field.key] === true;
            } else {
              el.value = fm[field.key] != null ? String(fm[field.key]) : '';
            }
          }

          richEditor.dataset.unknownLines = JSON.stringify(unknownLines);
          setRichBody(body.replace(/^\n+/, ''));

          editor.style.display = 'none';
          richEditor.classList.add('is-active');
          assetsToggle.style.display = 'none';

          if (assetDrawer.classList.contains('is-open')) {
            assetDrawer.classList.remove('is-open');
            assetsToggle.setAttribute('aria-expanded', 'false');
          }

          modeBtnRich.setAttribute('aria-pressed', 'true');
          modeBtnMdx.setAttribute('aria-pressed', 'false');
          activeMode = 'rich';
        } else {
          editor.value = serializeToMdx();

          richEditor.classList.remove('is-active');
          editor.style.display = '';
          assetsToggle.style.display = '';

          modeBtnRich.setAttribute('aria-pressed', 'false');
          modeBtnMdx.setAttribute('aria-pressed', 'true');
          activeMode = 'mdx';
        }
      }

      modeBtnRich.addEventListener('click', () => {
        if (activeMode !== 'rich') activateMode('rich');
      });
      modeBtnMdx.addEventListener('click', () => {
        if (activeMode !== 'mdx') activateMode('mdx');
      });

      // ── Load existing content ──────────────────────────────────
      if (!isNew) {
        fetch(`${cmsBase}/api/content/${slug}`)
          .then(r => r.json())
          .then(data => {
            if (data.content !== undefined) editor.value = data.content;
            activateMode('rich');
          })
          .catch(() => setStatus('Failed to load', 'error'));
      } else {
        editor.value = `---\ntitle: \ndescription: \n---\n\n`;
        activateMode('rich');
        const titleEl = document.getElementById('fm-title');
        if (titleEl) titleEl.focus();
      }

      // ── Dirty tracking (MDX textarea) ──────────────────────────
      editor.addEventListener('input', () => {
        if (!dirty) { dirty = true; setStatus('Unsaved changes', ''); }
      });

      // ── Cmd/Ctrl+S ─────────────────────────────────────────────
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 's') { e.preventDefault(); save(); }
      });

      saveBtn.addEventListener('click', save);

      async function save() {
        if (isNew) {
          const rawSlug = slugInput?.value?.trim();
          if (!rawSlug) { setStatus('Enter a slug first', 'error'); slugInput?.focus(); return; }
          currentSlug = rawSlug.toLowerCase().replace(/\s+/g, '-').replace(/^\/+/, '');
        }

        if (activeMode === 'rich') {
          editor.value = serializeToMdx();
        }

        saveBtn.disabled = true;
        setStatus('Saving…', 'saving');

        try {
          const res = await fetch(`${cmsBase}/api/content/${currentSlug}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: editor.value }),
          });

          if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            throw new Error(err.error ?? `HTTP ${res.status}`);
          }

          dirty = false;
          setStatus('Saved', 'saved');

          if (isNew) { window.location.href = `${cmsBase}/edit/${currentSlug}`; return; }
          if (previewFrame) previewFrame.src = previewFrame.src;

        } catch (err) {
          setStatus(`Error: ${err.message}`, 'error');
        } finally {
          saveBtn.disabled = false;
        }
      }

      function setStatus(msg, type) {
        statusEl.textContent = msg;
        statusEl.className = 'topbar__status' + (type ? ` topbar__status--${type}` : '');
      }

      window.addEventListener('beforeunload', (e) => {
        if (dirty) { e.preventDefault(); e.returnValue = ''; }
      });

      // ── Asset drawer ───────────────────────────────────────────
      let assetsLoaded = false;

      assetsToggle.addEventListener('click', () => {
        const open = assetDrawer.classList.toggle('is-open');
        assetsToggle.setAttribute('aria-expanded', String(open));
        if (open && !assetsLoaded) loadAssets();
      });

      async function loadAssets() {
        try {
          const res = await fetch(`${cmsBase}/api/assets/list`);
          const { assets } = await res.json();
          assetsLoaded = true;
          renderAssets(assets);
        } catch {
          assetGrid.innerHTML = '<div class="asset-empty">Failed to load assets</div>';
        }
      }

      function renderAssets(assets) {
        if (!assets.length) {
          assetGrid.innerHTML = '<div class="asset-empty">No images yet — upload one above</div>';
          return;
        }
        assetGrid.innerHTML = '';
        for (const asset of assets) {
          const item = document.createElement('div');
          item.className = 'asset-item';
          item.title = `Click to copy MDX snippet for ${asset.name}`;
          item.innerHTML = `
            <img class="asset-item__thumb" src="${asset.path}" alt="${asset.name}" loading="lazy" />
            <span class="asset-item__name">${asset.name}</span>
            <div class="asset-item__copied">Copied!</div>
          `;
          item.addEventListener('click', () => copySnippet(item, asset));
          assetGrid.appendChild(item);
        }
      }

      function copySnippet(item, asset) {
        const snippet = `<Image src="${asset.path}" alt="${asset.name}" />`;
        navigator.clipboard.writeText(snippet).then(() => {
          item.classList.add('did-copy');
          setTimeout(() => item.classList.remove('did-copy'), 1200);
        });
      }

      // ── Upload ─────────────────────────────────────────────────
      fileInput.addEventListener('change', async () => {
        const files = Array.from(fileInput.files ?? []);
        if (!files.length) return;

        setUploadStatus(`Uploading ${files.length} file${files.length > 1 ? 's' : ''}…`, 'uploading');

        const results = await Promise.allSettled(files.map(uploadFile));

        const failed = results.filter(r => r.status === 'rejected').length;
        if (failed) {
          setUploadStatus(`${failed} upload(s) failed`, 'err');
        } else {
          setUploadStatus(`Uploaded ${files.length} file${files.length > 1 ? 's' : ''}`, 'ok');
          setTimeout(() => setUploadStatus('', ''), 3000);
        }

        fileInput.value = '';
        assetsLoaded = false;
        loadAssets();
      });

      async function uploadFile(file) {
        const form = new FormData();
        form.append('file', file);
        const res = await fetch(`${cmsBase}/api/assets/upload`, { method: 'POST', body: form });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error ?? `HTTP ${res.status}`);
        }
        return res.json();
      }

      function setUploadStatus(msg, type) {
        uploadStatus.textContent = msg;
        uploadStatus.className = 'upload-status' + (type ? ` upload-status--${type}` : '');
      }
    </script>
  </body>
</html>
