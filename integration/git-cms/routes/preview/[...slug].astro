---
/**
 * Preview route: /preview/<slug>
 *
 * Injected by the gitcms integration — dev only, absent from production builds.
 * Reads the MDX file from disk and compiles it fresh on every request so edits
 * are visible immediately without a rebuild.
 */
export const prerender = false;

import { readFile } from 'node:fs/promises';
import { existsSync } from 'node:fs';
import { join, resolve } from 'node:path';
import { compile, run } from '@mdx-js/mdx';
import * as runtime from 'astro/jsx-runtime';
import matter from 'gray-matter';
import Layout from '@gitcms-project/layouts/Layout.astro';
import { mdxComponents } from '@gitcms-project/components/mdx-components';
import { recmaUnknownComponents } from '../../recma-unknown-components.js';

const { slug } = Astro.params;

if (!slug) {
  return new Response('Not found', { status: 404 });
}

const contentDir = import.meta.env.GITCMS_CONTENT_DIR ?? 'content';
const contentRoot = resolve(contentDir);
const filePath = join(contentRoot, `${slug}.mdx`);

if (!existsSync(filePath)) {
  return new Response(`Preview not found: ${slug}`, { status: 404 });
}

const raw = await readFile(filePath, 'utf-8');
const { data: frontmatter, content: mdxBody } = matter(raw);

const compiled = await compile(mdxBody, {
  outputFormat: 'function-body',
  development: false,
  recmaPlugins: [recmaUnknownComponents],
});

const { default: Content } = await run(compiled, {
  ...runtime,
  baseUrl: import.meta.url,
});

const cmsBase = import.meta.env.GITCMS_BASE ?? '/_cms';
const title = frontmatter.title ?? slug;
const description = frontmatter.description;
const isDraft = frontmatter.draft === true;
---

<Layout title={`Preview: ${title}`} description={description} preview={true}>
  <div class="preview-bar" aria-label="Preview mode indicator">
    <a class="preview-bar__cms-link" href={cmsBase}>gitcms</a>
    <span class="preview-bar__sep">/</span>
    <span class="preview-bar__badge">Preview</span>
    <span class="preview-bar__path">content/{slug}.mdx</span>
    {isDraft && <span class="preview-bar__draft">Draft</span>}
    <a class="preview-bar__edit-link" href={`${cmsBase}/edit/${slug}`}>Edit ✏︎</a>
  </div>
  <Content components={mdxComponents} />
</Layout>

<style>
  .preview-bar {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-2) var(--spacing-4);
    background-color: var(--color-brand-primary);
    color: var(--color-neutral-0);
    font-family: var(--font-family-base);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .preview-bar__cms-link {
    color: var(--color-neutral-0);
    text-decoration: none;
    font-weight: var(--font-weight-bold);
    opacity: 0.9;
  }
  .preview-bar__cms-link:hover { opacity: 1; text-decoration: underline; }

  .preview-bar__sep {
    opacity: 0.4;
  }

  .preview-bar__badge {
    background-color: var(--color-neutral-0);
    color: var(--color-brand-primary);
    padding: var(--spacing-1) var(--spacing-2);
    border-radius: var(--radius-sm);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
  }

  .preview-bar__path {
    opacity: 0.85;
    font-family: var(--font-family-mono);
  }

  .preview-bar__draft {
    background-color: var(--color-warning);
    color: var(--color-neutral-0);
    padding: var(--spacing-1) var(--spacing-2);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
  }

  .preview-bar__edit-link {
    margin-left: auto;
    color: var(--color-neutral-0);
    text-decoration: none;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    padding: var(--spacing-1) var(--spacing-2);
    border: 1px solid rgb(255 255 255 / 0.4);
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-duration-base);
  }
  .preview-bar__edit-link:hover {
    background-color: rgb(255 255 255 / 0.15);
  }
</style>
